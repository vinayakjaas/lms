# ─── API Configuration ───────────────────────────────────────────────
# URL of your deployed Railway backend, ending in /api
# Example: https://lms-backend-production.up.railway.app/api
VITE_API_URL=https://your-backend.railway.app/api

# ─── Auth Cookie ─────────────────────────────────────────────────────
# Must match backend STUDENT_COOKIE_NAME (default: lms_student)
VITE_STUDENT_COOKIE_NAME=lms_student
