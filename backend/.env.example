# ─── MongoDB ─────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=aiugip_lms

# ─── JWT / Auth ───────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# ─── App URLs ────────────────────────────────────────────────────────
# Public URL of this backend (used in certificate QR codes, emails, etc.)
BASE_URL=https://your-backend.railway.app

# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=https://your-frontend.vercel.app

# ─── Cookie Settings ─────────────────────────────────────────────────
# Set to true in production (HTTPS only)
COOKIE_SECURE=true
STUDENT_COOKIE_NAME=lms_student
STUDENT_COOKIE_HTTPONLY=false
# For cross-site frontend (Vercel) -> backend (Railway), required so the browser sends cookies
# on fetch/XHR after refresh. Ensure COOKIE_SECURE=true when using "none".
STUDENT_COOKIE_SAMESITE=none

# ─── File Storage (Cloudflare R2) ────────────────────────────────────
# Create an R2 API token at: https://dash.cloudflare.com > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# Public URL for serving stored files (custom domain or R2 public bucket URL)
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─── Email / OTP (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ─── Upload Directories (relative to backend root) ───────────────────
UPLOAD_DIR=uploads
CERTIFICATE_DIR=uploads/certificates
